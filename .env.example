# MongoDB
MONGODB_URI=mongodb://localhost:27017/sleek-syllabus

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Server
PORT=5000
NODE_ENV=development

# Frontend (Next.js) — must match backend URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# Gemini AI — get a key at https://aistudio.google.com/app/apikey
# Keys must start with "AIza". Place this in server/.env (not project root).
GEMINI_API_KEY=AIzaSy_your_key_here
